---
/**
 * Interactive: drag the dot on any curve; all three move to the same input x.
 * Saturated (flat) dots dim to show where the gradient nearly vanishes. (Lesson 3.3.)
 */
const W = 140, H = 130, pad = 18;
const xmin = -4, xmax = 4;
const sx = (x: number) => pad + ((x - xmin) / (xmax - xmin)) * (W - 2 * pad);
const sy = (y: number, ymin: number, ymax: number) => (H - pad) - ((y - ymin) / (ymax - ymin)) * (H - 2 * pad);
const fns = [
  { name: 'tanh', ymin: -1.2, ymax: 1.2, color: '#C96F5A' },
  { name: 'sigmoid', ymin: -0.1, ymax: 1.1, color: '#7E7FBC' },
  { name: 'relu', ymin: -0.4, ymax: 4, color: '#5E80C9' },
];
const evalF = (name: string, x: number) =>
  name === 'tanh' ? Math.tanh(x) : name === 'sigmoid' ? 1 / (1 + Math.exp(-x)) : Math.max(0, x);
const panels = fns.map((fn) => {
  const pts: string[] = [];
  for (let x = xmin; x <= xmax + 1e-9; x += 0.2) pts.push(`${sx(x).toFixed(1)},${sy(evalF(fn.name, x), fn.ymin, fn.ymax).toFixed(1)}`);
  return { ...fn, curve: pts.join(' '), y0: sy(0, fn.ymin, fn.ymax), x0: sx(0) };
});
const startX = 1;
---

<div class="mt-demo mt-activations-demo my-6 bg-white border border-mt-border rounded-2xl p-6"
     data-w={W} data-h={H} data-pad={pad} data-xmin={xmin} data-xmax={xmax}>
    <p class="text-xs uppercase tracking-wide text-mt-muted font-semibold mb-1 text-center">Drag a dot, one input <span class="font-mono">x</span>, three squashers</p>
    <p class="text-center text-xs text-mt-muted mb-4">drag far out and the dot dims, that's saturation, where the slope is ~0</p>

    <div class="grid grid-cols-3 gap-3">
        {panels.map((p) => (
            <div class="text-center" data-panel data-name={p.name} data-ymin={p.ymin} data-ymax={p.ymax}>
                <svg viewBox={`0 0 ${W} ${H}`} class="w-full" role="img" aria-label={p.name + " curve, drag the dot"}>
                    <line x1={pad} y1={p.y0} x2={W - pad} y2={p.y0} stroke="#E8E4DF" stroke-width="1" />
                    <line x1={p.x0} y1={pad} x2={p.x0} y2={H - pad} stroke="#F0EDE9" stroke-width="1" />
                    <polyline points={p.curve} fill="none" stroke={p.color} stroke-width="2.5" stroke-linecap="round" />
                    <circle data-dot cx={sx(startX)} cy={sy(evalF(p.name, startX), p.ymin, p.ymax)} r="6" fill={p.color} stroke="#fff" stroke-width="2" class="mt-grab" />
                </svg>
                <div class="font-mono text-xs mt-1" style={`color:${p.color}`}>{p.name}</div>
                <div class="font-mono text-xs text-mt-muted">out = <span data-out>0.76</span></div>
            </div>
        ))}
    </div>
    <p class="text-center text-xs text-mt-muted mt-3">grab any dot and slide it left or right</p>
</div>

<script>
    import { gsap, svgPoint, clamp } from '../../lib/interact';
    const evalF = (name: string, x: number) =>
        name === 'tanh' ? Math.tanh(x) : name === 'sigmoid' ? 1 / (1 + Math.exp(-x)) : Math.max(0, x);
    const slopeF = (name: string, x: number) => {
        if (name === 'tanh') { const t = Math.tanh(x); return 1 - t * t; }
        if (name === 'sigmoid') { const s = 1 / (1 + Math.exp(-x)); return s * (1 - s); }
        return x > 0 ? 1 : 0;
    };

    document.querySelectorAll<HTMLElement>('.mt-activations-demo').forEach((root) => {
        const W = Number(root.dataset.w), H = Number(root.dataset.h), pad = Number(root.dataset.pad);
        const xmin = Number(root.dataset.xmin), xmax = Number(root.dataset.xmax);
        const sx = (x: number) => pad + ((x - xmin) / (xmax - xmin)) * (W - 2 * pad);
        const sy = (y: number, a: number, b: number) => (H - pad) - ((y - a) / (b - a)) * (H - 2 * pad);
        const invX = (px: number) => clamp(xmin + ((px - pad) / (W - 2 * pad)) * (xmax - xmin), xmin, xmax);
        const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-panel]'));
        let x = 1;

        function render() {
            panels.forEach((p) => {
                const name = p.dataset.name!, ymin = Number(p.dataset.ymin), ymax = Number(p.dataset.ymax);
                const y = evalF(name, x), flat = Math.abs(slopeF(name, x)) < 0.1;
                const dot = p.querySelector<SVGCircleElement>('[data-dot]')!;
                p.querySelector<HTMLElement>('[data-out]')!.textContent = y.toFixed(2);
                gsap.to(dot, { attr: { cx: sx(x), cy: sy(y, ymin, ymax) }, opacity: flat ? 0.3 : 1, duration: 0.15, overwrite: true });
            });
        }
        panels.forEach((p) => {
            const svg = p.querySelector<SVGSVGElement>('svg')!;
            const dot = p.querySelector<SVGCircleElement>('[data-dot]')!;
            const set = (e: PointerEvent) => { x = invX(svgPoint(svg, e).x); render(); };
            dot.addEventListener('pointerdown', (e) => { dot.setPointerCapture(e.pointerId); set(e); });
            dot.addEventListener('pointermove', (e) => { if (dot.hasPointerCapture(e.pointerId)) set(e); });
            // tapping anywhere on a panel also moves to that x
            svg.addEventListener('pointerdown', (e) => { if (e.target !== dot) set(e); });
        });
        render();
    });
</script>
