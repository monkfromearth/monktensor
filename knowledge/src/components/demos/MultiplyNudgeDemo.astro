---
/**
 * Interactive: drag a's bar; c = a x b grows b times as fast, shown as a bar that is
 * always b times longer. Direct manipulation, no slider. (Lessons 0.1 / 0.3.)
 */
interface Props {
  b?: number;
}
const { b = 3 } = Astro.props;
const domain = 12;     // both bars share this scale, so c visibly outruns a
const aMax = domain / b; // keep c on-screen (c = b*a <= domain)
const aStart = 2;
---

<div class="mt-multiply-demo my-6 bg-white border border-mt-border rounded-2xl p-6"
     data-b={b} data-domain={domain} data-amax={aMax} data-astart={aStart}>
    <p class="text-xs uppercase tracking-wide text-mt-muted font-semibold mb-1 text-center">Drag the <span class="text-mt-accent">a</span> bar</p>
    <p class="text-center text-xs text-mt-muted mb-5">c is always <span class="font-mono">b = {b}</span> times as long, so it grows <span class="font-mono">{b}&times;</span> as fast</p>

    <!-- big live readouts -->
    <div class="flex items-center justify-center gap-2 font-mono text-lg mb-6">
        <span class="px-3 py-1 rounded-lg bg-mt-accentLight text-mt-accent font-semibold" data-a>1.50</span>
        <span class="text-mt-muted">&times;</span>
        <span class="px-3 py-1 rounded-lg bg-stone-100 text-mt-muted">{b}</span>
        <span class="text-mt-muted">=</span>
        <span class="px-3 py-1 rounded-lg bg-mt-lavLight text-mt-lav font-semibold" data-c>4.50</span>
    </div>

    <!-- a: draggable bar -->
    <div class="mb-4">
        <div class="flex justify-between text-xs text-mt-muted mb-1"><span class="font-mono text-mt-accent">a</span><span class="font-mono" data-a2>1.50</span></div>
        <div data-atrack class="relative h-7 rounded-full bg-mt-bg cursor-ew-resize select-none touch-none" role="slider" aria-label="drag to set a" tabindex="0">
            <div data-abar class="absolute inset-y-0 left-0 rounded-full bg-mt-accent" style="width:12.5%"></div>
            <div data-ahandle class="absolute top-1/2 -translate-y-1/2 -translate-x-1/2 w-6 h-6 rounded-full bg-white border-2 border-mt-accent shadow" style="left:12.5%"></div>
        </div>
    </div>

    <!-- c: mirrors a at b times the length -->
    <div class="mb-2">
        <div class="flex justify-between text-xs text-mt-muted mb-1"><span class="font-mono text-mt-lav">c = a &times; b</span><span class="font-mono" data-c2>4.50</span></div>
        <div class="relative h-7 rounded-full bg-mt-bg">
            <div data-cbar class="absolute inset-y-0 left-0 rounded-full bg-mt-lav" style="width:37.5%"></div>
        </div>
    </div>

    <p class="text-center text-xs text-mt-muted mt-4">that fixed ratio &mdash; how much c moves per step of a &mdash; is the derivative <span class="font-mono">dc/da = b</span></p>
</div>

<script>
    import { gsap } from 'gsap';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    document.querySelectorAll<HTMLElement>('.mt-multiply-demo').forEach((root) => {
        const b = Number(root.dataset.b);
        const domain = Number(root.dataset.domain);
        const aMax = Number(root.dataset.amax);
        const track = root.querySelector<HTMLElement>('[data-atrack]')!;
        const aBar = root.querySelector<HTMLElement>('[data-abar]')!;
        const aHandle = root.querySelector<HTMLElement>('[data-ahandle]')!;
        const cBar = root.querySelector<HTMLElement>('[data-cbar]')!;
        const aOut = root.querySelectorAll<HTMLElement>('[data-a],[data-a2]');
        const cOut = root.querySelectorAll<HTMLElement>('[data-c],[data-c2]');

        const setBar = (el: HTMLElement, pct: number) =>
            reduce ? (el.style.width = pct + '%') : gsap.to(el, { width: pct + '%', duration: 0.18, ease: 'power2.out', overwrite: true });

        let a = Number(root.dataset.astart);
        function render() {
            const c = a * b;
            aOut.forEach((e) => (e.textContent = a.toFixed(2)));
            cOut.forEach((e) => (e.textContent = c.toFixed(2)));
            setBar(aBar, (a / domain) * 100);
            setBar(cBar, (c / domain) * 100);
            const handlePct = (a / domain) * 100;
            reduce ? (aHandle.style.left = handlePct + '%')
                   : gsap.to(aHandle, { left: handlePct + '%', duration: 0.18, ease: 'power2.out', overwrite: true });
        }

        let dragging = false;
        const STEP = 0.5; // discrete, easy-to-land values (a = 0, 0.5, 1.0, …)
        const fromEvent = (clientX: number) => {
            const r = track.getBoundingClientRect();
            const frac = Math.min(1, Math.max(0, (clientX - r.left) / r.width));
            a = Math.min(aMax, Math.max(0, Math.round((frac * domain) / STEP) * STEP));
            render();
        };
        track.addEventListener('pointerdown', (e) => { dragging = true; track.setPointerCapture(e.pointerId); fromEvent(e.clientX); });
        track.addEventListener('pointermove', (e) => { if (dragging) fromEvent(e.clientX); });
        track.addEventListener('pointerup', () => { dragging = false; });
        track.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowRight' || e.key === 'ArrowUp') { a = Math.min(aMax, a + STEP); render(); e.preventDefault(); }
            if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') { a = Math.max(0, a - STEP); render(); e.preventDefault(); }
        });
        render();
    });
</script>
