---
/**
 * Interactive: grab gear A and spin it; B turns 3x as much, C turns 6x.
 * Rates multiply along the chain (3 x 2 = 6) = the chain rule. (Lesson 0.5.)
 */
const gears = [
  { id: 'A', cx: 70, cy: 110, r: 38, color: '#C96F5A', mult: 1 },
  { id: 'B', cx: 190, cy: 110, r: 38, color: '#7E7FBC', mult: 3 },
  { id: 'C', cx: 310, cy: 110, r: 38, color: '#5E80C9', mult: 6 },
];
const teeth = 10;
function tooth(cx: number, cy: number, r: number, k: number) {
  const a = (k / teeth) * Math.PI * 2;
  const c = Math.cos(a), s = Math.sin(a);
  return { x1: cx + r * c, y1: cy + r * s, x2: cx + (r + 7) * c, y2: cy + (r + 7) * s };
}
---

<div class="mt-demo mt-gears-demo my-6 bg-white border border-mt-border rounded-2xl p-6">
    <p class="text-xs uppercase tracking-wide text-mt-muted font-semibold mb-1 text-center">Grab gear <span class="text-mt-accent">A</span> and spin it</p>
    <p class="text-center text-xs text-mt-muted mb-2">B turns 3&times; as much, C turns 6&times;, the rates multiply down the chain</p>

    <svg viewBox="0 0 380 200" class="w-full max-w-lg mx-auto block" role="img" aria-label="three gears; spinning A spins B three times and C six times as much">
        <text x="130" y="58" text-anchor="middle" class="font-mono" fill="#6B6560" font-size="13">&times;3</text>
        <text x="250" y="58" text-anchor="middle" class="font-mono" fill="#6B6560" font-size="13">&times;2</text>
        <line x1="108" y1="110" x2="152" y2="110" stroke="#E8E4DF" stroke-width="2" />
        <line x1="228" y1="110" x2="272" y2="110" stroke="#E8E4DF" stroke-width="2" />

        {gears.map((g) => (
            <g data-gear data-cx={g.cx} data-cy={g.cy} data-mult={g.mult}>
                {Array.from({ length: teeth }).map((_, k) => {
                    const t = tooth(g.cx, g.cy, g.r, k);
                    return <line x1={t.x1} y1={t.y1} x2={t.x2} y2={t.y2} stroke={g.color} stroke-width="5" stroke-linecap="round" />;
                })}
                <circle cx={g.cx} cy={g.cy} r={g.r} fill="none" stroke={g.color} stroke-width="6" />
                <circle cx={g.cx} cy={g.cy} r="6" fill={g.color} />
                <line x1={g.cx} y1={g.cy} x2={g.cx} y2={g.cy - g.r} stroke={g.color} stroke-width="3" />
                <circle cx={g.cx} cy={g.cy - g.r + 9} r="4" fill="#fff" stroke={g.color} stroke-width="2" />
            </g>
        ))}
        {gears.map((g) => <text x={g.cx} y={g.cy + g.r + 22} text-anchor="middle" class="font-mono font-bold" fill={g.color} font-size="14">{g.id}</text>)}
        <!-- big invisible grab target over gear A -->
        <circle data-grabA cx="70" cy="110" r="48" fill="transparent" class="mt-grab" />
    </svg>

    <div class="flex items-center justify-center gap-3 font-mono text-sm">
        <span class="px-3 py-1 rounded-lg bg-mt-accentLight text-mt-accent">A <span data-out="1">0&deg;</span></span>
        <span class="px-3 py-1 rounded-lg bg-mt-lavLight text-mt-lav">B <span data-out="3">0&deg;</span></span>
        <span class="px-3 py-1 rounded-lg bg-mt-blueLight text-mt-blue font-semibold">C <span data-out="6">0&deg;</span></span>
    </div>
    <p class="text-center text-xs text-mt-muted mt-3">C turns <span class="font-mono">6&times;</span> as fast as A, because <span class="font-mono">3 &times; 2 = 6</span></p>
</div>

<script>
    import { gsap, svgPoint } from '../../lib/interact';

    document.querySelectorAll<HTMLElement>('.mt-gears-demo').forEach((root) => {
        const svg = root.querySelector<SVGSVGElement>('svg')!;
        const gears = Array.from(root.querySelectorAll<SVGGElement>('[data-gear]'));
        const grab = root.querySelector<SVGCircleElement>('[data-grabA]')!;
        const outs = root.querySelectorAll<HTMLElement>('[data-out]');
        const Acx = 70, Acy = 110;

        let aAng = 0;            // gear A's angle in degrees
        const angleAt = (e: PointerEvent) => {
            const p = svgPoint(svg, e);
            return (Math.atan2(p.y - Acy, p.x - Acx) * 180) / Math.PI;
        };
        function apply() {
            gears.forEach((g) => {
                const m = Number(g.dataset.mult), cx = Number(g.dataset.cx), cy = Number(g.dataset.cy);
                gsap.set(g, { rotation: aAng * m, svgOrigin: `${cx} ${cy}` });
            });
            outs.forEach((o) => (o.textContent = Math.round(aAng * Number(o.dataset.out)) + '°'));
        }

        let startPointer = 0, startA = 0, on = false;
        grab.addEventListener('pointerdown', (e) => { on = true; grab.setPointerCapture(e.pointerId); startPointer = angleAt(e); startA = aAng; });
        grab.addEventListener('pointermove', (e) => {
            if (!on) return;
            let delta = angleAt(e) - startPointer;
            // unwrap across the -180/180 seam
            if (delta > 180) delta -= 360; if (delta < -180) delta += 360;
            aAng = startA + delta;
            apply();
        });
        const end = () => { on = false; };
        grab.addEventListener('pointerup', end);
        grab.addEventListener('pointercancel', end);
        apply();
    });
</script>
