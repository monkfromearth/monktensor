---
/**
 * Interactive: turn gear A, gears B and C turn 3x and 6x as much.
 * Rates multiply down the chain (x3 then x2 = x6) = the chain rule. (Lesson 0.5.)
 */
const gears = [
  { id: 'A', cx: 70,  cy: 110, r: 38, color: '#C96F5A', mult: 1 },
  { id: 'B', cx: 190, cy: 110, r: 38, color: '#7E7FBC', mult: 3 },
  { id: 'C', cx: 310, cy: 110, r: 38, color: '#5E80C9', mult: 6 },
];
const teeth = 10;
function tooth(cx: number, cy: number, r: number, k: number) {
  const a = (k / teeth) * Math.PI * 2;
  const c = Math.cos(a), s = Math.sin(a);
  return { x1: cx + r * c, y1: cy + r * s, x2: cx + (r + 7) * c, y2: cy + (r + 7) * s };
}
---

<div class="mt-gears-demo my-6 bg-white border border-mt-border rounded-2xl p-6">
    <p class="text-xs uppercase tracking-wide text-mt-muted font-semibold mb-4 text-center">Turn gear <span class="font-mono">A</span> &mdash; the chain multiplies</p>

    <svg viewBox="0 0 380 200" class="w-full max-w-lg mx-auto block" role="img" aria-label="three gears; turning A turns B three times as much and C six times as much">
        <!-- multiplier badges between gears -->
        <text x="130" y="60" text-anchor="middle" class="font-mono" fill="#6B6560" font-size="13">&times;3</text>
        <text x="250" y="60" text-anchor="middle" class="font-mono" fill="#6B6560" font-size="13">&times;2</text>
        <line x1="108" y1="110" x2="152" y2="110" stroke="#E8E4DF" stroke-width="2" />
        <line x1="228" y1="110" x2="272" y2="110" stroke="#E8E4DF" stroke-width="2" />

        {gears.map((g) => (
            <g data-gear data-cx={g.cx} data-cy={g.cy} data-mult={g.mult}>
                {Array.from({ length: teeth }).map((_, k) => {
                    const t = tooth(g.cx, g.cy, g.r, k);
                    return <line x1={t.x1} y1={t.y1} x2={t.x2} y2={t.y2} stroke={g.color} stroke-width="5" stroke-linecap="round" />;
                })}
                <circle cx={g.cx} cy={g.cy} r={g.r} fill="none" stroke={g.color} stroke-width="6" />
                <circle cx={g.cx} cy={g.cy} r="6" fill={g.color} />
                <!-- spoke + rim dot make rotation visible -->
                <line x1={g.cx} y1={g.cy} x2={g.cx} y2={g.cy - g.r} stroke={g.color} stroke-width="3" />
                <circle cx={g.cx} cy={g.cy - g.r + 9} r="4" fill="#fff" stroke={g.color} stroke-width="2" />
            </g>
        ))}
        {/* labels live outside the rotating group so they stay upright */}
        {gears.map((g) => (
            <text x={g.cx} y={g.cy + g.r + 22} text-anchor="middle" class="font-mono font-bold" fill={g.color} font-size="14">{g.id}</text>
        ))}
    </svg>

    <div class="flex items-center justify-center gap-3 font-mono text-sm mt-2 mb-4">
        <span class="px-3 py-1 rounded-lg bg-mt-accentLight text-mt-accent">A <span data-out="1">0&deg;</span></span>
        <span class="px-3 py-1 rounded-lg bg-mt-lavLight text-mt-lav">B <span data-out="3">0&deg;</span></span>
        <span class="px-3 py-1 rounded-lg bg-mt-blueLight text-mt-blue font-semibold">C <span data-out="6">0&deg;</span></span>
    </div>

    <input type="range" min="0" max="120" step="1" value="0" data-slider class="w-full accent-mt-accent cursor-pointer" aria-label="how much to turn gear A" />

    <p class="text-center text-xs text-mt-muted mt-3">C turns <span class="font-mono">6&times;</span> as fast as A, because <span class="font-mono">3 &times; 2 = 6</span>. Rates multiply along the chain.</p>
</div>

<script>
    import { gsap } from 'gsap';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    document.querySelectorAll<HTMLElement>('.mt-gears-demo').forEach((root) => {
        const slider = root.querySelector<HTMLInputElement>('[data-slider]')!;
        const gearEls = root.querySelectorAll<SVGGElement>('[data-gear]');
        const outs = root.querySelectorAll<HTMLElement>('[data-out]');
        const dur = reduce ? 0 : 0.3;

        function update() {
            const a = Number(slider.value); // degrees A turns
            gearEls.forEach((g) => {
                const mult = Number(g.dataset.mult);
                const cx = Number(g.dataset.cx), cy = Number(g.dataset.cy);
                gsap.to(g, { rotation: a * mult, svgOrigin: `${cx} ${cy}`, duration: dur, overwrite: true });
            });
            outs.forEach((o) => {
                const m = Number(o.dataset.out);
                o.textContent = Math.round(a * m) + '°';
            });
        }
        slider.addEventListener('input', update);
        update();
    });
</script>
