---
/**
 * Fan-out as two streams pouring into one bucket. x is used twice, so two gradients
 * flow back and ADD (+=). Flip to Overwrite (=) and watch a path get lost. (Lesson 2.2.)
 */
---

<div class="mt-demo mt-accumulate-demo my-6 bg-white border border-mt-border rounded-2xl p-6">
    <p class="text-xs uppercase tracking-wide text-mt-muted font-semibold mb-1 text-center">Backward pass of <span class="font-mono">y = x &times; x</span></p>
    <p class="text-center text-xs text-mt-muted mb-4">x feeds two slots, so two gradients (each = x) come back to it</p>

    <svg viewBox="0 0 360 170" class="w-full max-w-md mx-auto block" role="img" aria-label="two gradient streams pouring into x's bucket">
        <!-- two source pipes -->
        <text x="300" y="34" text-anchor="middle" class="font-mono" font-size="10" fill="#7E7FBC">slot 1: +<tspan data-xval>3</tspan></text>
        <text x="300" y="140" text-anchor="middle" class="font-mono" font-size="10" fill="#5E80C9">slot 2: +<tspan data-xval2>3</tspan></text>
        <path d="M300 42 Q 200 50 150 78" fill="none" stroke="#ECEAF6" stroke-width="6" />
        <path d="M300 128 Q 200 120 150 96" fill="none" stroke="#EAF0FB" stroke-width="6" />

        <!-- the bucket (x.grad accumulator) -->
        <rect x="70" y="40" width="64" height="90" rx="8" fill="#FAF8F5" stroke="#C96F5A" stroke-width="2" />
        <rect data-fill x="72" y="128" width="60" height="0" rx="6" fill="#C96F5A" opacity="0.8" />
        <text x="102" y="32" text-anchor="middle" class="font-mono" font-size="10" fill="#6B6560">x.grad</text>
        <text data-grad x="102" y="90" text-anchor="middle" class="font-mono" font-size="18" font-weight="bold" fill="#C96F5A">0</text>

        <!-- droplets -->
        <circle data-drop="1" cx="300" cy="42" r="6" fill="#7E7FBC" opacity="0" />
        <circle data-drop="2" cx="300" cy="128" r="6" fill="#5E80C9" opacity="0" />
    </svg>

    <div class="flex flex-wrap items-center justify-center gap-2 mt-2">
        <div class="inline-flex rounded-lg border border-mt-border overflow-hidden text-sm">
            <button data-mode="add" class="px-3 py-1.5 bg-mt-accent text-white font-semibold">add (+=)</button>
            <button data-mode="set" class="px-3 py-1.5 bg-white text-mt-muted">overwrite (=)</button>
        </div>
        <button data-run class="px-4 py-2 rounded-lg bg-mt-lav text-white text-sm font-semibold hover:opacity-90 transition">Run backward</button>
        <span class="text-xs text-mt-muted">x:</span>
        <button data-x="-1" class="w-7 h-7 rounded-lg bg-stone-100 text-mt-muted">&minus;</button>
        <button data-x="1" class="w-7 h-7 rounded-lg bg-stone-100 text-mt-muted">+</button>
    </div>
    <p class="text-center text-xs text-mt-muted mt-3" data-verdict>add both paths &rarr; <span class="font-mono">2x</span>, the right answer. Overwrite and the second path replaces the first &mdash; a path is lost.</p>
</div>

<script>
    import { gsap, REDUCED } from '../../lib/interact';

    document.querySelectorAll<HTMLElement>('.mt-accumulate-demo').forEach((root) => {
        let x = 3, mode: 'add' | 'set' = 'add';
        const gradEl = root.querySelector<SVGTextElement>('[data-grad]')!;
        const fill = root.querySelector<SVGRectElement>('[data-fill]')!;
        const verdict = root.querySelector<HTMLElement>('[data-verdict]')!;
        const drop = (i: string) => root.querySelector<SVGCircleElement>(`[data-drop="${i}"]`)!;
        const maxH = 88, maxGrad = 10;
        const proxy = { v: 0 };
        const draw = () => {
            gradEl.textContent = String(Math.round(proxy.v));
            const h = Math.min(proxy.v / maxGrad, 1) * maxH;
            fill.setAttribute('height', String(h));
            fill.setAttribute('y', String(128 - h));
        };
        const syncX = () => {
            root.querySelector<HTMLElement>('[data-xval]')!.textContent = String(x);
            root.querySelector<HTMLElement>('[data-xval2]')!.textContent = String(x);
            verdict.innerHTML = mode === 'add'
                ? `both paths add &rarr; <span class="font-mono">x + x = ${2 * x}</span> = 2x. Correct.`
                : `overwrite: the second path replaces the first &rarr; <span class="font-mono">${x}</span> = x. A path is lost.`;
        };
        const reset = () => { gsap.killTweensOf([proxy, drop('1'), drop('2')]); proxy.v = 0; draw(); gsap.set([drop('1'), drop('2')], { opacity: 0 }); };
        const pour = (i: string, sx: number, sy: number, delay: number, target: number) => {
            const d = drop(i);
            if (REDUCED) return;
            gsap.timeline({ delay })
                .set(d, { attr: { cx: sx, cy: sy }, opacity: 1 })
                .to(d, { attr: { cx: 102, cy: 122 }, duration: 0.5, ease: 'power1.in' })
                .to(proxy, { v: target, duration: 0.25, onUpdate: draw }, '>-0.05')
                .to(d, { opacity: 0, duration: 0.1 });
        };
        function run() {
            reset();
            const t1 = x, t2 = mode === 'add' ? 2 * x : x; // explicit targets per slot
            pour('1', 300, 42, 0, t1);
            pour('2', 300, 128, 0.8, t2);
            if (REDUCED) { proxy.v = t2; draw(); }
        }
        root.querySelectorAll<HTMLButtonElement>('[data-mode]').forEach((b) =>
            b.addEventListener('click', () => {
                mode = b.dataset.mode as 'add' | 'set';
                root.querySelectorAll<HTMLButtonElement>('[data-mode]').forEach((o) => {
                    const on = o === b;
                    o.classList.toggle('bg-mt-accent', on); o.classList.toggle('text-white', on);
                    o.classList.toggle('bg-white', !on); o.classList.toggle('text-mt-muted', !on);
                });
                syncX(); reset();
            }));
        root.querySelectorAll<HTMLButtonElement>('[data-x]').forEach((b) =>
            b.addEventListener('click', () => { x = Math.max(1, Math.min(5, x + Number(b.dataset.x))); syncX(); reset(); }));
        root.querySelector('[data-run]')!.addEventListener('click', run);
        syncX(); reset();
    });
</script>
