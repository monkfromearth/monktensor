---
/**
 * Interactive: drag the inputs a, b, c; values flow forward through e = (a x b) + c.
 * The edges animate a current toward the output. (Lesson 1.2.)
 */
const inputs = [
  { id: 'a', cx: 60, cy: 50, color: '#C96F5A', light: '#FBEEE9' },
  { id: 'b', cx: 60, cy: 115, color: '#C96F5A', light: '#FBEEE9' },
  { id: 'c', cx: 60, cy: 180, color: '#C96F5A', light: '#FBEEE9' },
];
const d = { cx: 185, cy: 82, color: '#7E7FBC', light: '#F0F0FB' };
const e = { cx: 300, cy: 128, color: '#5E80C9', light: '#EEF3FC' };
const edges = [
  { from: [82, 50], to: [165, 78] }, { from: [82, 115], to: [165, 86] },
  { from: [207, 82], to: [280, 122] }, { from: [82, 180], to: [280, 134] },
];
---

<div class="mt-demo mt-forward-demo my-6 bg-white border border-mt-border rounded-2xl p-6">
    <p class="text-xs uppercase tracking-wide text-mt-muted font-semibold mb-1 text-center">Drag the inputs &mdash; values flow forward to <span class="font-mono">e</span></p>
    <p class="text-center text-xs text-mt-muted mb-3"><span class="font-mono">e = (a &times; b) + c</span></p>

    <svg viewBox="0 0 360 230" class="w-full max-w-md mx-auto block" role="img" aria-label="drag inputs; values flow forward through the graph">
        {edges.map((g) => <line x1={g.from[0]} y1={g.from[1]} x2={g.to[0]} y2={g.to[1]} stroke="#C2C0D8" stroke-width="2.5" stroke-linecap="round" data-flow stroke-dasharray="1 7" />)}

        <!-- input tracks -->
        {inputs.map((n) => <line x1={n.cx} y1={n.cy - 30} x2={n.cx} y2={n.cy + 30} stroke="#EFE8E2" stroke-width="6" stroke-linecap="round" />)}

        <!-- computed nodes -->
        <g>
            <circle cx={d.cx} cy={d.cy} r="22" fill={d.light} stroke={d.color} stroke-width="2" />
            <text x={d.cx} y={d.cy - 3} text-anchor="middle" font-size="9" fill="#6B6560" class="font-mono">a&times;b</text>
            <text data-node="d" x={d.cx} y={d.cy + 10} text-anchor="middle" class="font-mono" font-size="12" font-weight="bold" fill={d.color}>-6</text>
            <circle cx={e.cx} cy={e.cy} r="24" fill={e.light} stroke={e.color} stroke-width="2.5" />
            <text x={e.cx} y={e.cy - 4} text-anchor="middle" font-size="9" fill="#6B6560" class="font-mono">e</text>
            <text data-node="e" x={e.cx} y={e.cy + 11} text-anchor="middle" class="font-mono" font-size="14" font-weight="bold" fill={e.color}>4</text>
        </g>

        <!-- input nodes + drag handles -->
        {inputs.map((n) => (
            <g>
                <text x={n.cx - 16} y={n.cy + 4} text-anchor="end" class="font-mono" font-size="12" fill={n.color}>{n.id}</text>
                <circle data-drag={n.id} cx={n.cx} cy={n.cy} r="13" fill="#fff" stroke={n.color} stroke-width="2.5" class="mt-grab" />
                <text data-node={n.id} x={n.cx} y={n.cy + 4} text-anchor="middle" class="font-mono" font-size="11" fill={n.color}>2</text>
            </g>
        ))}
    </svg>
    <p class="text-center text-xs text-mt-muted mt-2">the same operations run in the same order every time &mdash; that order is the graph</p>
</div>

<script>
    import { gsap, svgPoint, clamp, REDUCED } from '../../lib/interact';

    document.querySelectorAll<HTMLElement>('.mt-forward-demo').forEach((root) => {
        const svg = root.querySelector<SVGSVGElement>('svg')!;
        const node = (k: string) => root.querySelector<SVGTextElement>(`[data-node="${k}"]`)!;
        const tracks: Record<string, number> = { a: 50, b: 115, c: 180 };
        const state: Record<string, number> = { a: 2, b: -3, c: 10 };
        const vFor = (cy: number, y: number) => clamp(Math.round((5 - ((y - (cy - 30)) / 60) * 10)), -5, 5);
        const yFor = (cy: number, v: number) => cy - 30 + ((5 - v) / 10) * 60;

        function render() {
            (['a', 'b', 'c'] as const).forEach((k) => {
                node(k).textContent = String(state[k]);
                const h = root.querySelector<SVGCircleElement>(`[data-drag="${k}"]`)!;
                const ny = yFor(tracks[k], state[k]);
                h.setAttribute('cy', String(ny));
                node(k).setAttribute('y', String(ny + 4));
            });
            const dv = state.a * state.b, ev = dv + state.c;
            node('d').textContent = String(dv);
            node('e').textContent = String(ev);
        }
        (['a', 'b', 'c'] as const).forEach((k) => {
            const h = root.querySelector<SVGCircleElement>(`[data-drag="${k}"]`)!;
            const set = (e: PointerEvent) => { state[k] = vFor(tracks[k], svgPoint(svg, e).y); render(); };
            h.addEventListener('pointerdown', (e) => { h.setPointerCapture(e.pointerId); set(e); });
            h.addEventListener('pointermove', (e) => { if (h.hasPointerCapture(e.pointerId)) set(e); });
        });
        render();
        // a steady current along the edges shows the forward direction
        if (!REDUCED) gsap.to(root.querySelectorAll('[data-flow]'), { strokeDashoffset: -16, duration: 0.9, repeat: -1, ease: 'none' });
    });
</script>
